# Copy this file to .env and fill in your provider key.
# .env is ignored by Git and must not be committed.

# Any OpenAI-compatible Chat Completions provider can be used here.
# Examples: OpenAI, OpenRouter, Groq, together.ai, or a self-hosted Llama gateway.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
LLM_TIMEOUT_SECONDS=20
